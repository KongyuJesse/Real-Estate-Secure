# Mobile-only build variables
# Copy this file to `.env` and fill the values for local development.

# Google Maps Android SDK key.
# Enable "Maps SDK for Android" and restrict this key by:
# package name: com.example.real_estate_secure
# SHA-1 fingerprint: your local debug or release signing certificate
GOOGLE_MAPS_API_KEY=

# Optional Android AdMob application id.
# The Google sample test app id is used automatically in debug if this is empty.
ADMOB_ANDROID_APP_ID=

# Optional backend base URL used for real devices during local development.
# Example: http://192.168.100.89:8080/v1
RES_API_BASE_URL=
# Debug examples:
# - Android emulator: http://10.0.2.2:8080/v1
# - USB-connected physical Android: http://127.0.0.1:8080/v1

# Optional runtime dart-defines for map styling and live ads:
# flutter run --dart-define=GOOGLE_MAPS_ANDROID_MAP_ID=your_android_map_id
# flutter run --dart-define=GOOGLE_MAPS_IOS_MAP_ID=your_ios_map_id
# flutter run --dart-define=ADMOB_ANDROID_BANNER_ID=your_release_android_banner_id
# flutter run --dart-define=ADMOB_IOS_BANNER_ID=your_release_ios_banner_id
# flutter run --dart-define=ADMOB_ANDROID_INTERSTITIAL_ID=your_release_android_interstitial_id
# flutter run --dart-define=ADMOB_IOS_INTERSTITIAL_ID=your_release_ios_interstitial_id
