{
  "name": "real-estate-secure-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js + Express backend for the Real Estate Secure platform.",
  "main": "src/server.js",
  "scripts": {
    "migrate": "node scripts/migrate.js",
    "migrate:seed": "node scripts/migrate.js --with-seeds",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/main.js",
    "check": "node -e \"require('./src/app'); console.log('backend ok')\"",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^21.3.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "pg": "^8.13.1",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  }
}
